APP_NAME=PEMIQ
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://pemiq.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=pemiq
DB_USERNAME=pemiq
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=postmark
POSTMARK_TOKEN=
MAIL_FROM_ADDRESS="noreply@pemiq.com"
MAIL_FROM_NAME="${APP_NAME}"

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=https://pemiq.com/strava/callback
